<UserControl x:Class="NaturalLanguageWizard.TextPredictor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:NaturalLanguageWizard">
    <Grid>
        <Popup Name="popup">
            <ListBox Name="listbox" Height="0" SelectionChanged="listbox_SelectionChanged" VerticalAlignment="Top" VerticalContentAlignment="Top" HorizontalAlignment="Left" Width="91" />
        </Popup>
        <TextBox x:Name="textbox" IsEnabled="False" PreviewTextInput="textbox_PreviewTextInput" KeyUp="textbox_KeyUp" Foreground="Black" PreviewLostKeyboardFocus="textbox_PreviewLostKeyboardFocus" HorizontalAlignment="Left" Width="91" PreviewKeyDown="textbox_PreviewKeyDown" />
        <Image Name="filter" Source="filter.png" Margin="97,0,0,0" Visibility="Hidden" HorizontalAlignment="Left" Width="102" ToolTip="Filtered"/>
        <TextBlock Name="tbkDescription" TextAlignment="Left" Margin="136,0,0,0" TextWrapping="Wrap"  />
    </Grid>
</UserControl>
