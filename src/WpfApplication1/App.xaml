                        <Setter Property="ToolTip" Value="{me:Info Image='/images/Answer.png',Title='Text: Enter',Body=TextEnterTypeToolTip}"/>
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ComboBox}}, Path=Name}" Value="cmbAnsType"/>
                            <Condition Binding="{Binding ID}" Value="22"/>
