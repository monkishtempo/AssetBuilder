<Application x:Class="AssetBuilder.App"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:me="clr-namespace:AssetBuilder"
	xmlns:asset="clr-namespace:AssetBuilder.AssetControls"
    xmlns:AssetBuilder_Controls="clr-namespace:AssetBuilder.Controls" 
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:r="http://schemas.microsoft.com/winfx/2006/xaml/presentation/ribbon" 
	StartupUri="Window1.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Simple Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <me:ExistsConverter x:Key="ExistsConverter" />
            <ControlTemplate x:Key="thumbStyle" TargetType="Thumb" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
                <Border BorderThickness="{TemplateBinding Border.BorderThickness}" BorderBrush="{TemplateBinding Border.BorderBrush}" Background="{TemplateBinding Panel.Background}">
                    <Grid>
                        <!--<Border BorderThickness="0,0,1,1" BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkDarkBrushKey}}" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" />
						<Border BorderThickness="0,0,1,1" BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" Background="{DynamicResource {x:Static SystemColors.ControlLightLightBrushKey}}" Margin="1,1,1,1" />
						<Border Background="{TemplateBinding Panel.Background}" Margin="2,2,2,2" />-->
                    </Grid>
                </Border>
            </ControlTemplate>
            <Style x:Key="LongToolTip">
                <Setter Property="ToolTipService.ShowDuration" Value="600000"/>
            </Style>
            <Style TargetType="DataGridCell" BasedOn="{StaticResource LongToolTip}" />
            <Style x:Key="TextBlockWrapping">
                <Setter Property="TextBlock.TextWrapping" Value="Wrap"></Setter>
            </Style>
            <Style TargetType="DataGridRow">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding x_Background, Converter={StaticResource ExistsConverter}}" Value="True">
                        <Setter Property="Background" Value="{Binding x_Background}"></Setter>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding x_Foreground, Converter={StaticResource ExistsConverter}}" Value="True">
                        <Setter Property="Foreground" Value="{Binding x_Foreground}"></Setter>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding x_FontSize, Converter={StaticResource ExistsConverter}}" Value="True">
                        <Setter Property="FontSize" Value="{Binding x_FontSize}"></Setter>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding x_FontWeight, Converter={StaticResource ExistsConverter}}" Value="True">
                        <Setter Property="FontWeight" Value="{Binding x_FontWeight}"></Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource LongToolTip}">
                <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
            </Style>
            <Style x:Key="FilterButton" TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource LongToolTip}">
                <Setter Property="Margin" Value="0,0,0,28" />
                <Setter Property="Padding" Value="4" />
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="VerticalAlignment" Value="Bottom" />
                <Setter Property="Width" Value="24" />
                <Setter Property="Height" Value="24" />
                <Setter Property="Focusable" Value="False" />
                <Setter Property="ToolTip">
                    <Setter.Value>
                        <me:Info Title="Filter" Image="/images/funnel-icon.png" Body="FilterToolTip" />
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsChecked" Value="False">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate>
                                    <Border CornerRadius="3">
                                        <Border.Background>
                                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                                <GradientStop Color="#FFE8E8E8" Offset="0"/>
                                                <GradientStop Color="White" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Image Width="16" Height="16" Source="/images/Funnel_disabled.png" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate>
                                    <Border CornerRadius="3">
                                        <Border.Background>
                                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                                <GradientStop Color="#FFFDB10F" Offset="0"/>
                                                <GradientStop Color="White" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Image Width="16" Height="16" Source="/images/Funnel_enabled.png" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style TargetType="{x:Type r:RibbonToggleButton}" BasedOn="{StaticResource LongToolTip}" />
            <Style TargetType="{x:Type r:RibbonGroup}" BasedOn="{StaticResource LongToolTip}" />
            <Style TargetType="Frame" BasedOn="{StaticResource LongToolTip}" />
            <Style TargetType="Label" BasedOn="{StaticResource LongToolTip}"/>
            <Style x:Key="AssetTextBoxPadding">
                <Setter Property="TextBox.Padding" Value="2,4,2,2" />
            </Style>
            <Style x:Key="AssetComboBoxPadding">
                <Setter Property="ComboBox.Padding" Value="2,4,2,2" />
            </Style>
            <Style TargetType="Image" BasedOn="{StaticResource LongToolTip}" />
            <Style TargetType="TextBlock" BasedOn="{StaticResource LongToolTip}" />
            <Style x:Key="ColouredListBoxItem" TargetType="ListBoxItem" BasedOn="{StaticResource LongToolTip}">
                <Setter Property="ToolTip" Value="{Binding ToolTip}"/>
                <Setter Property="Background" Value="#FFE0FFE0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                            <Border x:Name="Bd" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                                <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding NotInUse}" Value="1">
                                    <Setter Property="Background" TargetName="Bd" Value="#FFFFFFD0"/>
                                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                                </DataTrigger>
                                <Trigger Property="IsSelected" Value="true">
                                    <Setter Property="Background" TargetName="Bd" Value="Green"/>
                                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"/>
                                </Trigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding CategoryTypeID}" Value="0" />
                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="true" />
                                        <!--<Condition Binding="{Binding Audit, Converter={StaticResource ExistsConverter}}" Value="false" />-->
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Background" TargetName="Bd" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="true" />
                                        <Condition Binding="{Binding Audit, Converter={StaticResource ExistsConverter}}" Value="true" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Background" TargetName="Bd" Value="{StaticResource AuditHighlightBrush}"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding NotInUse}" Value="1" />
                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="true" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Background" TargetName="Bd" Value="Goldenrod"/>
                                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding NotInUse}" Value="1" />
                                        <Condition Binding="{Binding IsChecked, ElementName=hideUnused}" Value="true" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </MultiDataTrigger>
                                <!--<MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsSelected" Value="true"/>
                                        <Condition Property="Selector.IsSelectionActive" Value="false"/>
                                    </MultiTrigger.Conditions>
                                    <Setter Property="Background" TargetName="Bd" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"/>
                                </MultiTrigger>-->
                                <Trigger Property="IsEnabled" Value="false">
                                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <!--<DataTrigger Binding="{Binding Audit, Converter={StaticResource ExistsConverter}}" Value="True">
                        <Setter Property="Foreground" Value="Purple" />
                    </DataTrigger>-->
                    <DataTrigger Binding="{Binding Audit.Type}" Value="Edited">
                        <Setter Property="Foreground" Value="Purple" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Audit.Type}" Value="Copyedit approval">
                        <Setter Property="Foreground" Value="BlueViolet" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Audit.Type}" Value="Clincal approval">
                        <Setter Property="Foreground" Value="Blue" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Audit.Type}" Value="No change needed">
                        <Setter Property="Foreground" Value="DarkGreen" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding CategoryTypeID}" Value="{x:Null}">
                        <Setter Property="Background" Value="#FFFFFFFA" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding CategoryTypeID}" Value="0">
                        <Setter Property="Background" Value="#FFFFFFFA" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding HasLanguage}" Value="True">
                        <Setter Property="ContentTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Value}"/>
                                        <TextBlock Foreground="Red" TextWrapping="Wrap" FontSize="12" HorizontalAlignment="Right" Text="{Binding Language}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Hidden}" Value="True">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
