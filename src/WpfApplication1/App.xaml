            <Style x:Key="ToolTipStyle">
                <Style.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="TextWrapping" Value="Wrap" />
                    </Style>
                </Style.Resources>
            </Style>
            <Style x:Key="SliderCheckBoxStyle" TargetType="CheckBox">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <DockPanel>
                                <TextBlock Margin="0,0,6,0" Text="{TemplateBinding Content}" />
                                <Grid Width="32" Height="16">
                                    <Canvas>
                                        <Border x:Name="SwitchSlider" Width="32" Height="16" CornerRadius="10" Background="#ddd" />
                                        <Border x:Name="SwitchThumb" Canvas.Left="1" Canvas.Top="1" Width="14" Height="14" CornerRadius="8" Background="White" BorderBrush="#ccc" BorderThickness="1" />
                                    </Canvas>
                                </Grid>
                            </DockPanel>

                            <ControlTemplate.Triggers>
                                <Trigger x:Name="CheckedTrigger" Property="IsChecked" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="SwitchThumb"
                                                     Storyboard.TargetProperty="(Canvas.Left)"
                                                     To="17" Duration="0:0:0.2" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="SwitchThumb"
                                                     Storyboard.TargetProperty="(Canvas.Left)"
                                                     To="1" Duration="0:0:0.2" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                    <Setter TargetName="SwitchSlider" Property="Background" Value="#00cc00" />
                                </Trigger>

                                <Trigger x:Name="UnCheckedTrigger" Property="IsChecked" Value="False">
                                    <Setter TargetName="SwitchSlider" Property="Background" Value="#ddd" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
