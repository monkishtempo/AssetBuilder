                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock><Run>'</Run><Run Foreground="Red" Text="{Binding .}" /><Run>'</Run></TextBlock>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
