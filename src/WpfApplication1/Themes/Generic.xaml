                                <Button ToolTip="{me:Info Body=btnDeriveQuestionToolTip, Title=Derive Question}" x:Name="btnDeriveQuestion" Content="Derive Question" Padding="10,0,10,0"  Margin="0,0,5,0"/>
                                <Button ToolTip="{me:Info Body=btnCreateAnswerToolTip, Title=Create Answer}" x:Name="btnCreateAnswer" Content="Create Answer" Padding="10,0,10,0"  Margin="0,0,5,0" IsEnabled="False"/>
                                <Button ToolTip="{me:Info Body=btnPropertiesToolTip, Title=Properties}" x:Name="btnProperties" Content="Properties" Padding="10,0,10,0"  Margin="0,0,5,0" IsEnabled="True"/>
                                <Button ToolTip="{me:Info Body=btnCancelToolTip, Title=Cancel}" x:Name="btnCancel" Content="Cancel" Padding="10,0,10,0"  Margin="0,0,5,0"/>
                                <Button ToolTip="{me:Info Body=btnSaveToolTip, Title=Save}" x:Name="btnSave" Content="Save" Padding="10,0,10,0"  Margin="0,0,5,0"/>
                                <Button ToolTip="{me:Info Body=btnFindToolTip, Image=/images/Equals.png, Title=Find/Replace}" x:Name="btnFind" Content="Find/Replace" Padding="10,0,10,0"  Margin="0,0,5,0"/>
                                <!--<Button ToolTip="{me:Info Body=btnNLWToolTip, Title=Natural Language}" x:Name="btnNLW" Content="Natural Language" Padding="10,0,10,0"  Margin="0,0,5,0"/>-->
                                <AssetBuilder_Controls:countIndicator x:Name="PropertyCount" Number="0" VerticalAlignment="Bottom" Height="24" />
                            </DockPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

