<local:ABWindow x:Class="AssetBuilder.NaturalLanguage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:AssetBuilder.Controls"
    Title="NaturalLanguage"  Height="600" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <local:ABRichTextBox Grid.Row="0" Grid.Column="0" x:Name="text1" x:FieldModifier="public" />
        <StackPanel Grid.Row="0" Grid.Column="1" x:Name="controls1"/>
        <DockPanel Grid.ColumnSpan="2" Grid.Row="1">
            <WebBrowser x:Name="render1"></WebBrowser>
        </DockPanel>
        <DockPanel Grid.ColumnSpan="2" Grid.Row="2">
            <Button x:Name="btnSave" Content="Save"></Button>
        </DockPanel>
    </Grid>
</local:ABWindow>
