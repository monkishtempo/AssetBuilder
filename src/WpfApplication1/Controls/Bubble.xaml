<UserControl
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	x:Class="AssetBuilder.Bubble"
	x:Name="UserControl"
	>

	<Grid MinWidth="160" MaxWidth="320">
		<Grid.RowDefinitions>
			<RowDefinition />
			<RowDefinition Height="45"/>
		</Grid.RowDefinitions>
		<Rectangle Grid.Row="0" Fill="White" Stroke="White" RadiusX="30" RadiusY="30" Margin="0,0,5,-2">
			<Rectangle.Effect>
				<DropShadowEffect Color="#FF6C5555" Opacity="0.5"/>
			</Rectangle.Effect>
		</Rectangle>
		<Path Fill="White" Grid.Row="1" Data="M35,0 C45,10 35,20 5,40 C75,0 85,0 105,0" Stroke="White" Margin="0,0,0,0.4">
			<Path.Effect>
				<DropShadowEffect Color="#FF6C5555" Opacity="0.5"/>
			</Path.Effect>
		</Path>
		<TextBlock x:Name="content" Padding="20,20,20,18" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="14.667">
			21 Oct 2007 ... Search Windows Presentation Foundation (WPF) Forum; Search All .NET Development Forums ... the data triggers in the above example are even easier. ... Is there a way to bind a data item to the splitter's position? ...
		</TextBlock>
	</Grid>
</UserControl>